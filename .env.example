# API Keys (solo necesitas una)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Configuración del Scraper de X
X_USERNAME=zuler
X_MAX_TWEETS=200
X_SCROLL_COUNT=20
X_HEADLESS=true

# Configuración del Scraper de CoinMarketCap
CMC_MAX_ARTICLES=20
CMC_DOWNLOAD_IMAGES=true

# Configuración del Modelo
MODEL_PROVIDER=anthropic
# Opciones: claude-3-5-sonnet-20241022, gpt-4-turbo-preview
MODEL_NAME=claude-3-5-sonnet-20241022
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=2000

# Paths (opcional, usa defaults si no se especifica)
DATA_DIR=data
OUTPUT_DIR=output
MODELS_DIR=models
IMAGES_DIR=images
